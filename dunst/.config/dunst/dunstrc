[global]
    alignment = left
    follow = mouse
    font = UbuntuMono Nerd Font Mono 9
    format = "<b>%s</b>: %b"
    history_length = 20
    horizontal_padding = 8
    icon_position = off
    idle_threshold = 120 
    ignore_newline = no
    indicate_hidden = yes
    line_height = 0
    markup = full
    monitor = 0
    offset = 0x20
    origin = top-center
    padding = 4
    progress_bar_height = 16
    separator_height = 1
    show_indicators = yes
    shrink = yes
    sort = yes
    sticky_history = yes
    transparency = 20
    word_wrap = yes
    frame_width = 1
    
[low]
    msg_urgency = low
    background = "#282A36"
    foreground = "#F8F8F2"
    frame_color = "#BFBFBF"
    highlight = "#BFBFBF"

[normal]
    msg_urgency = normal
    background = "#282A36"
    foreground = "#F8F8F2"
    frame_color = "#BFBFBF"
    highlight = "#BFBFBF"
    
[critical]
    msg_urgency = critical
    background = "#282A36"
    foreground = "#F8F8F2"
    frame_color = "#BFBFBF"
    highlight = "#BFBFBF"
